rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 어드민 판별 함수 (이메일 기반)
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'timbach@naver.com';
    }

    // 로그인한 본인 판별
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ── 사용자 정보 ──────────────────────────────────────
    // 본인 문서: 읽기/쓰기 가능
    // 어드민: 전체 읽기/쓰기 가능
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── 주문 ─────────────────────────────────────────────
    // 본인 주문: 생성 및 읽기 가능 (취소는 update로 처리)
    // 어드민: 전체 읽기/업데이트 가능
    match /orders/{orderId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── 상담 신청 ─────────────────────────────────────────
    // 누구나 생성 가능 (비로그인 사용자도 상담 신청 허용)
    // 읽기/수정은 어드민만 가능
    match /consultations/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ── 제품 ─────────────────────────────────────────────
    // 누구나 읽기 가능 (카탈로그 공개)
    // 쓰기는 어드민만 가능
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── 사이트 설정 (CMS) ─────────────────────────────────
    // 누구나 읽기 가능 (홈페이지 콘텐츠 공개)
    // 쓰기는 어드민만 가능
    match /site_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
